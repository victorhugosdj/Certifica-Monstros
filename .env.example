# ============================================================
# VARIÁVEIS DE AMBIENTE - Certifica Monstros
# ============================================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha os valores com suas credenciais do Supabase
# 3. NÃO COMMITE o arquivo .env ao Git (.gitignore já protege)
#
# ============================================================

# SUPABASE - URLs e Chaves
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...sua_chave_anon_aqui
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...sua_chave_service_aqui

# BACKEND
BACKEND_HOST=localhost
BACKEND_PORT=8000
ENVIRONMENT=development

# CORS - Origens permitidas
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://127.0.0.1:5500

# ============================================================
# COMO OBTER ESSAS CREDENCIAIS:
# ============================================================
#
# 1. Entre em https://app.supabase.com
# 2. Selecione seu projeto
# 3. Vá em Settings → API
# 4. Copie:
#    - Project URL → SUPABASE_URL
#    - anon public key → SUPABASE_KEY
#    - service_role key → SUPABASE_SERVICE_KEY
#
# ⚠️ IMPORTANTE: service_role key é SENSÍVEL - NUNCA COMPARTILHE!
#
# ============================================================
